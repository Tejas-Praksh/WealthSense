# ──────────────────────────────────────────────────
# Build & IDE
# ──────────────────────────────────────────────────
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ──────────────────────────────────────────────────
# IntelliJ IDEA
# ──────────────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr

# ──────────────────────────────────────────────────
# Eclipse
# ──────────────────────────────────────────────────
.classpath
.project
.settings/
bin/

# ──────────────────────────────────────────────────
# VS Code
# ──────────────────────────────────────────────────
.vscode/

# ──────────────────────────────────────────────────
# NetBeans
# ──────────────────────────────────────────────────
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# ──────────────────────────────────────────────────
# OS Files
# ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ──────────────────────────────────────────────────
# Environment & Secrets
# ──────────────────────────────────────────────────
.env
*.env.local
*.env.production

# ──────────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────────
*.log
logs/**
!logs/.gitkeep

# ──────────────────────────────────────────────────
# Docker
# ──────────────────────────────────────────────────
docker-compose.override.yml

# ──────────────────────────────────────────────────
# Package Files
# ──────────────────────────────────────────────────
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# ──────────────────────────────────────────────────
