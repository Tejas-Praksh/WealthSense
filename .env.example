# ──────────────────────────────────────────────────
# WealthSense Environment Configuration
# Copy this file to .env and update the values
# ──────────────────────────────────────────────────

# Database
POSTGRES_DB=wealthsense
POSTGRES_USER=wealthsense
POSTGRES_PASSWORD=wealthsense123
POSTGRES_URL=jdbc:postgresql://localhost:5432/wealthsense

# MongoDB
MONGO_URI=mongodb://admin:admin123@localhost:27017/wealthsense

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=admin
RABBITMQ_PASSWORD=admin123

# JWT
JWT_SECRET=your-256-bit-secret-key-here-change-in-production
JWT_EXPIRATION=86400000

# AI Keys
CLAUDE_API_KEY=your-claude-api-key
GEMINI_API_KEY=your-gemini-api-key

# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
WEBHOOK_SECRET=your-webhook-secret-here

# Security encryption
ENCRYPTION_KEY=your-base64-encoded-32-byte-key

# App
APP_PORT=8080
APP_ENV=development
